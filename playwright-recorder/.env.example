OMNIA_URL=https://api2.optica-omnia.de

# Pflicht: Identifiziert den Arbeitsplatz gegenueber der Web-App. Werte stammen
# aus der optica.sign-Datei der bestehenden Windows-Installation.
# Auf Windows liegt sie unter C:\ProgramData\Optica_Omnia\optica.sign oder
# %APPDATA%\Optica Omnia\optica.sign. Inhalt ist base64-codiertes JSON.
# Entweder Werte direkt eintragen ...
OMNIA_MACHINE_ID=
OMNIA_TENANT_ID=
# ... oder optica.sign-Datei lokal vorhalten und Pfad setzen:
OMNIA_OPTICA_SIGN_PATH=
# Optional: vorgegaukelte App-Version
OMNIA_APP_VERSION=stub-0.0.0

# Optional: nur setzen, wenn du Login-Felder automatisieren willst.
# Standard ist manueller Login im sichtbaren Browserfenster.
OMNIA_USERNAME=
OMNIA_PASSWORD=
OMNIA_USERNAME_SELECTOR=
OMNIA_PASSWORD_SELECTOR=
OMNIA_SUBMIT_SELECTOR=

# Optional: 1 speichert JSON-Response-Bodies aus /apigateway/ in captures/bodies.
OMNIA_CAPTURE_BODIES=1

# Optional: 0 deaktiviert das Redacten sensibler Header (Authorization, Cookie, ...).
# Standard 1: sensible Header werden in captures als [REDACTED] gespeichert.
OMNIA_REDACT_HEADERS=1
