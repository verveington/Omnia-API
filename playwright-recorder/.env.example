OMNIA_URL=https://api2.optica-omnia.de

# Pflicht: Identifiziert den Arbeitsplatz gegenueber der Web-App. Werte stammen
# aus der optica.sign-Datei der bestehenden Windows-Installation.
# Auf Windows liegt sie unter C:\ProgramData\Optica_Omnia\optica.sign oder
# %APPDATA%\Optica Omnia\optica.sign. Inhalt ist base64-codiertes JSON.
# Entweder Werte direkt eintragen ...
OMNIA_MACHINE_ID=
OMNIA_TENANT_ID=
# ... oder optica.sign-Datei lokal vorhalten und Pfad setzen:
OMNIA_OPTICA_SIGN_PATH=
# Optional: vorgegaukelte App-Version
OMNIA_APP_VERSION=stub-0.0.0

# Optional: nur setzen, wenn du Login-Felder automatisieren willst.
# Standard ist manueller Login im sichtbaren Browserfenster.
OMNIA_USERNAME=
OMNIA_PASSWORD=
OMNIA_USERNAME_SELECTOR=
OMNIA_PASSWORD_SELECTOR=
OMNIA_SUBMIT_SELECTOR=

# Optional: 1 speichert JSON-Response-Bodies aus /apigateway/ in captures/bodies.
OMNIA_CAPTURE_BODIES=1

# Optional: 0 deaktiviert das Redacten sensibler Header (Authorization, Cookie, ...).
# Standard 1: sensible Header werden in captures als [REDACTED] gespeichert.
OMNIA_REDACT_HEADERS=1

# Optional: native Windows-/Electron-App per Parallels + Chrome DevTools Protocol steuern.
# native:probe/native:session starten eine separate kontrollierte Omnia-Instanz.
OMNIA_VM_NAME=Windows 11
# Leer lassen: wird aus `prlctl list -i` gelesen. Nur setzen, wenn Auto-Erkennung scheitert.
OMNIA_VM_IP=
OMNIA_NATIVE_APP_PATH=C:\Users\christophschernthane\AppData\Local\Programs\Optica Omnia\Optica Omnia.exe
OMNIA_NATIVE_PROFILE_PATH=C:\Temp\omnia-cdp-profile
OMNIA_NATIVE_GUEST_DEBUG_PORT=9225
OMNIA_NATIVE_HOST_DEBUG_PORT=9226
OMNIA_NATIVE_CONNECT_TIMEOUT_MS=30000
# Standard: 1 fuer C:\Temp\omnia-cdp-* Profile, sonst 0.
OMNIA_NATIVE_CLEAN_PROFILE=

# Optional: lokales Web-Panel fuer Spracheingabe.
OMNIA_VOICE_HOST=127.0.0.1
OMNIA_VOICE_PORT=8787
# Optional: none startet nur den Chat, launch startet Omnia, attach verbindet eine laufende Debug-App.
OMNIA_NATIVE_AUTOCONNECT=none
# Optional: persistenter Lernkatalog fuer natuerliche Sprachbefehle.
OMNIA_COMMAND_CATALOG_PATH=
# Optional: lokales oder per SSH getunneltes KI-Modell fuer Konversation.
# Default passt zu Ollama mit `ollama serve`.
OMNIA_AI_BASE_URL=http://127.0.0.1:11434/v1
OMNIA_AI_CHAT_ENDPOINT=
OMNIA_AI_MODEL=qwen2.5:7b
OMNIA_AI_API_KEY=ollama
# Optional: maximale Wartezeit auf lokale KI-Antworten.
OMNIA_AI_TIMEOUT_MS=8000
